  @@index([lapSetId, lapNumber])
}

enum VideoAnalysisJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

/** Fisheye (or fixed) camera setup for a track layout â€” reference frame + sector lines. */
model TrackCameraProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  trackId String

  name String @default("Main camera")

  /** Local path, blob URL, or `/uploads/...` for reference still. */
  referenceImagePath String?
  /** Optional OpenCV fisheye intrinsics JSON. */
  lensJson Json?
  /** Last known good homography (reference <- query) for drift hints. */
  lastAlignmentJson Json?

  sectorLines TrackSectorLine[]
  analysisJobs VideoAnalysisJob[]

  @@index([userId, trackId])
  @@index([trackId])
}

/** Sector / start-finish line in normalized [0,1] coords on the profile reference image. */
model TrackSectorLine {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  profile   TrackCameraProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String

  /** Stable id within profile, e.g. `sf`, `s1`. */
  lineKey   String
  label     String
  x1        Float
  y1        Float
  x2        Float
  y2        Float
  sortOrder Int @default(0)

  @@unique([profileId, lineKey])
  @@index([profileId, sortOrder])
}

model VideoAsset {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  /** Blob URL or local `/uploads/...` ref (see storage helpers). */
  storagePath      String
  originalFilename String
  mimeType         String
  bytes            Int
  /** Optional free-text label (e.g. "Q2 A-main onboard"). */
  label            String?

  /** Optional local path when analysis runs on device (not uploaded). */
  localAnalysisPath String?

  run   Run?   @relation(fields: [runId], references: [id], onDelete: SetNull)
  runId String?

  track   Track?  @relation(fields: [trackId], references: [id], onDelete: SetNull)
  trackId String?

  analysisJobs VideoAnalysisJob[]

  @@index([userId, createdAt])
  @@index([runId])
  @@index([trackId])
}

/** Video sector analysis job â€” results imported from Python worker JSON. */
model VideoAnalysisJob {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  status VideoAnalysisJobStatus @default(PENDING)

  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  trackId String

  profile   TrackCameraProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String

  videoAsset   VideoAsset? @relation(fields: [videoAssetId], references: [id], onDelete: SetNull)
  videoAssetId String?

  run   Run?   @relation(fields: [runId], references: [id], onDelete: SetNull)
  runId String?

  /** Per-session alignment (homography, inlier ratio, user overrides). */
  alignmentJson Json?
  /** Worker output: VideoAnalysisResultV1 (tracks, laps, sectors, idSwapHints). */
  resultJson Json?
  errorMessage String?

  /** Optional manual MOT id remaps: [{ fromId, toId, startSec, endSec }] */
  idCorrectionsJson Json?

  /** `worker` = Python JSON import; `manual` = user frame marks + transponder sync. */
  analysisMode String @default("worker")
  /** ManualVideoSessionV1 â€” sync anchors, sector frame marks, driver selection. */
  manualJson Json?

  @@index([userId, createdAt])
  @@index([trackId])
  @@index([runId])
}

