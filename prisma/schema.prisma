// Migration history reset for Postgres deployment.
// SQLite migrations removed. Fresh baseline will be generated after
// provider switch in next step.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  cars            Car[]
  runs            Run[]
  tracks          Track[]
  tireSets        TireSet[]
  tireTypesCreated TireType[] @relation("TireTypeCreatedBy")
  additiveTypesCreated AdditiveType[] @relation("AdditiveTypeCreatedBy")
  batteries       Battery[]
  snapshots       SetupSnapshot[]
  events          Event[]
  eventParticipations EventParticipation[]
  favouriteTracks FavouriteTrack[]
  trackLocationRunPromptDismissals TrackLocationRunPromptDismissal[]
  appSettings     AppSetting[]
  actionItems     ActionItem[]
  setupDocuments  SetupDocument[]
  setupCalibrations SetupSheetCalibration[]
  setupSheetModels  SetupSheetModel[]
  setupImportBatches SetupImportBatch[]
  importedLapTimeSessions ImportedLapTimeSession[]
  watchedLapSources WatchedLapSource[]
  videoAssets     VideoAsset[]
  trackCameraProfiles TrackCameraProfile[]
  videoAnalysisJobs   VideoAnalysisJob[]
  teammateLinksOwned TeammateLink[] @relation("TeammateLinksOwned")
  teammateLinksPeer  TeammateLink[] @relation("TeammateLinksPeer")
  engineerBetweenRunHints EngineerBetweenRunHint[]
  engineerDashboardSuggestions EngineerDashboardSuggestion[]
  engineerChatThreads EngineerChatThread[]
  engineerMessageRatings EngineerMessageRating[]
  engineerGoldSetCandidates EngineerGoldSetCandidate[]

  teamMemberships TeamMembership[]
  teamsCreated    Team[]           @relation("TeamsCreated")
}

/** Named group for mutual visibility pilot (members share runs in Engineer + team Sessions view). */
model Team {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  name      String

  createdByUserId String?
  createdBy       User? @relation("TeamsCreated", fields: [createdByUserId], references: [id], onDelete: SetNull)

  memberships TeamMembership[]
}

model TeamMembership {
  id       String   @id @default(cuid())
  joinedAt DateTime @default(now())
  teamId   String
  userId   String
  /** `admin` \| `member` â€” pilot uses `member` for everyone unless you promote in DB. */
  role     String   @default("member")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId])
}

/** Emails allowed to receive magic-link sign-in (invite list). */
model AuthAllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

/** Auth.js / NextAuth â€” OAuth-style account linkage (email magic link uses this). */
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

/** Auth.js database sessions (kept for adapter compatibility; app uses JWT sessions in middleware). */
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/** Viewer (`userId`) may browse peer runs in Engineer when same track (enforced in APIs + context). */
model TeammateLink {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String
  peerUserId String

  user User @relation("TeammateLinksOwned", fields: [userId], references: [id], onDelete: Cascade)
  peer User @relation("TeammateLinksPeer", fields: [peerUserId], references: [id], onDelete: Cascade)

  @@unique([userId, peerUserId])
  @@index([userId])
  @@index([peerUserId])
}

enum ActionItemSourceType {
  RUN
  MANUAL
}

enum ActionItemListKind {
  THINGS_TO_TRY
  THINGS_TO_DO
}

model ActionItem {
  id          String               @id @default(cuid())
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  text        String
  normKey     String
  listKind    ActionItemListKind   @default(THINGS_TO_TRY)
  /** User-visible order: lower = earlier in the list. */
  sortOrder   Int                  @default(0)
  sourceType  ActionItemSourceType
  sourceRunId String?
  isCompleted Boolean              @default(false)
  isArchived  Boolean              @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  sourceRun Run? @relation(fields: [sourceRunId], references: [id], onDelete: SetNull)

  @@index([userId, listKind, isArchived, sortOrder])
  @@index([userId, isArchived, createdAt])
  @@index([userId, listKind, normKey, isArchived])
}

/// Global setup sheet model (e.g. Mugen MTC3): parameter schema shared by every car of that chassis
/// across all users. Not user-owned — `userId` is creator attribution only.
model SetupSheetModel {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  name       String
  /// Stable id for aggregation and built-in seeds (e.g. mugen_mtc3, awesomatix_a800rr).
  slug       String
  schemaJson Json
  /// Confirmed/curated catalog entry (admin-managed). User-created models stay false until reviewed.
  isAuthorized Boolean @default(false)

  /// Creator (attribution only; models are shared globally). Null for seeded catalog entries.
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId String?

  cars           Car[]
  setupDocuments SetupDocument[]
  calibrations   SetupSheetCalibration[]
  /** PDF calibration used for auto-pick and the car-page â€œEdit PDF calibrationâ€ link. */
  defaultCalibrationId String?                @unique
  defaultCalibration   SetupSheetCalibration? @relation("ModelDefaultCalibration", fields: [defaultCalibrationId], references: [id], onDelete: SetNull)

  // NOTE: a global @@unique([slug]) is intentionally deferred until the one-time dedupe
  // (scripts/dedupe-setup-sheet-models.ts) has collapsed per-user duplicates in every environment.
  @@index([userId, updatedAt])
  @@index([slug])
}

/// Catalog slugs removed by an admin — global seed must not recreate them.
model SetupSheetCatalogSuppression {
  slug         String   @id
  suppressedAt DateTime @default(now())
  suppressedBy String?
}

model Car {
  id                 String   @id @default(cuid())
  name               String
  chassis            String?
  notes              String?
  setupSheetTemplate String?  // legacy: "awesomatix_a800rr" | null; prefer setupSheetModelId
  setupSheetModelId  String?
  createdAt          DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  setupSheetModel SetupSheetModel? @relation(fields: [setupSheetModelId], references: [id], onDelete: SetNull)

  runs      Run[]
  snapshots SetupSnapshot[]
  setupDocuments SetupDocument[]
  setupParameterAggregations SetupParameterAggregation[]

  @@index([setupSheetModelId])
}

model Track {
  id        String   @id @default(cuid())
  name      String
  location  String?
  /** GPS pin from â€œmark this locationâ€ when completing a run at the track. */
  latitude  Float?
  longitude Float?
  locationMarkedAt DateTime?
  /** How coordinates were set, e.g. `device`. */
  locationSource String?
  /** LiveRC track root URL (e.g. https://tftr.liverc.com) for session discovery. */
  liveRcUrl String?
  /** MYLAPS Speedhive organization page URL for session discovery. */
  speedhiveUrl String?
  /** Multi-select grip tags (e.g. MEDIUM + HIGH); see `trackMetaTags.ts` ids. */
  gripTags   String[] @default([])
  /** Multi-select layout tags (e.g. TECHNICAL + FAST). */
  layoutTags String[] @default([])
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  runs            Run[]
  events          Event[]
  favouriteTracks FavouriteTrack[]
  cameraProfiles  TrackCameraProfile[]
  videoAssets     VideoAsset[]
  videoAnalysisJobs VideoAnalysisJob[]
  locationRunPromptDismissals TrackLocationRunPromptDismissal[]
}

/** Per-user: do not show the Run-complete GPS modal again for this track. */
model TrackLocationRunPromptDismissal {
  userId      String
  trackId     String
  dismissedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([userId, trackId])
  @@index([trackId])
}

model FavouriteTrack {
  userId    String
  trackId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([userId, trackId])
}

model Event {
  id         String    @id @default(cuid())
  name       String
  startDate  DateTime
  endDate    DateTime
  createdAt  DateTime  @default(now())

  /// Creator (attribution only). Events are global per track/meeting.
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId String?

  track   Track?  @relation(fields: [trackId], references: [id], onDelete: SetNull)
  trackId String?

  /** Preserved when the linked Track row is deleted. */
  trackNameSnapshot     String?
  trackLocationSnapshot String?
  /** Full track catalog row at unlink/delete time (URLs, tags, GPS, etc.). */
  legacyTrackJson       Json?

  /** LiveRC practice session list URL for this event (optional — often added closer to the date). */
  practiceSourceUrl String?
  /** LiveRC results index URL for this event (optional — often added closer to the date). */
  resultsSourceUrl  String?
  /** Race class to watch on results index (e.g. \"17.5 Stock\"). */
  raceClass         String?

  /** Watermark for practice auto-import (canonical session completion instant). */
  practiceLastSeenSessionCompletedAt DateTime?
  /** Watermark for results auto-import. */
  resultsLastSeenSessionCompletedAt    DateTime?

  participations EventParticipation[]
  runs Run[]
  importedLapTimeSessions ImportedLapTimeSession[]
  // Future: timetable/scheduled sessions (timetableSessions?), reminders, "most likely session" suggestions

  // NOTE: partial UNIQUE(trackId, resultsSourceUrl) WHERE resultsSourceUrl IS NOT NULL is added in a
  // LATER migration after scripts/dedupe-events.ts collapses duplicate meeting rows.
  @@index([trackId, startDate])
  @@index([trackId, endDate])
}

/// Per-user link to a global event (spec tire, notes, dashboard pin).
model EventParticipation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String

  notes String?
  /** Legacy free-text spec tire label. */
  controlledTireLabel String?
  controlledTireType   TireType? @relation(fields: [controlledTireTypeId], references: [id], onDelete: SetNull)
  controlledTireTypeId String?

  controlledAdditiveType   AdditiveType? @relation(fields: [controlledAdditiveTypeId], references: [id], onDelete: SetNull)
  controlledAdditiveTypeId String?

  /** When set, prefer this event on the dashboard among active meetings. */
  pinnedAt DateTime?

  @@unique([userId, eventId])
  @@index([eventId])
}

/** Global tire additive catalog (shared across all users). */
model AdditiveType {
  id          String   @id @default(cuid())
  displayName String
  /** Unique product code — canonical identity. */
  modelCode   String   @unique
  createdAt   DateTime @default(now())

  createdBy   User?   @relation("AdditiveTypeCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdByUserId String?

  runs                 Run[]
  eventParticipations  EventParticipation[]

  @@index([displayName])
}

/** Global tire product catalog (shared across all users). */
model TireType {
  id          String   @id @default(cuid())
  displayName String
  /** Unique manufacturer/product code — canonical identity. */
  modelCode   String   @unique
  createdAt   DateTime @default(now())

  createdBy   User?   @relation("TireTypeCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdByUserId String?

  tireSets  TireSet[]
  eventParticipations EventParticipation[]

  @@index([displayName])
}

model TireSet {
  id         String   @id @default(cuid())
  /** Denormalized display label; legacy rows may use this without tireTypeId. */
  label      String
  setNumber  Int      @default(1) // individual set number
  initialRunCount Int @default(0) // optional starting run count (usually 0)
  /** Optional insert (e.g. medium soft). */
  insertLabel String?
  /** Optional wheel type. */
  wheelLabel  String?
  /** Optional specific product model for this physical set (e.g. premount SKU). */
  specificModel String?
  notes      String?
  createdAt  DateTime @default(now())

  tireType   TireType? @relation(fields: [tireTypeId], references: [id], onDelete: SetNull)
  tireTypeId String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  runs Run[]

  @@index([userId, tireTypeId, setNumber])
}

/** Reusable battery pack; run counts mirror TireSet (global per pack, linked via Run). */
model Battery {
  id              String   @id @default(cuid())
  label           String
  packNumber      Int      @default(1)
  initialRunCount Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  runs Run[]

  @@index([userId])
}

model SetupSnapshot {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  car   Car?  @relation(fields: [carId], references: [id], onDelete: SetNull)
  carId String?

  // Flexible JSON blob with setup parameters (geometry, shocks, diff, etc.)
  data Json

  /** Optional baseline snapshot this row was merged from (audit only; data is always full resolved). */
  baseSetupSnapshotId String?
  baseSetupSnapshot   SetupSnapshot?  @relation("SetupSnapshotBaseline", fields: [baseSetupSnapshotId], references: [id], onDelete: SetNull)
  derivedSnapshots    SetupSnapshot[] @relation("SetupSnapshotBaseline")

  /** Keys that differed from baseSetupSnapshot after merge (audit). */
  setupDeltaJson Json?

  /** Filled PDF from base template + calibration (same pipeline as runs); see `SETUP_PDF_RENDER_PIPELINE_VERSION`. */
  renderedSetupPdfPath          String?
  renderedSetupPdfGeneratedAt   DateTime?
  setupPdfRenderVersion         Int      @default(1)

  runs Run[]
  sourceDocuments SetupDocument[] @relation("CreatedSetup")
}

enum SetupDocumentSourceType {
  PDF
  IMAGE
}

enum SetupDocumentParseStatus {
  PENDING
  PARSED
  PARTIAL
  FAILED
}

enum SetupDocumentImportStatus {
  PENDING
  PROCESSING
  FAILED
  COMPLETED
  COMPLETED_WITH_WARNINGS
}

enum SetupDocumentImportOutcome {
  COMPLETED_TRUSTED
  COMPLETED_WITH_WARNINGS
  PARTIAL_DIAGNOSTIC
  FAILED
}

/**
 * CAR_PARAMETER: all eligible snapshots per car (scopeKey = carId).
 * CAR_PARAMETER_CONDITION: runs bucketed by track grip/layout signature (scopeKey = encoded condition).
 */
enum SetupAggregationScopeType {
  CAR_PARAMETER
  CAR_PARAMETER_CONDITION
}

enum SetupAggregationValueType {
  NUMERIC
  CATEGORICAL
  BOOLEAN
  MULTI_SELECT
}

/**
 * Materialized stats from normalized SetupSnapshot.data (via SetupDocument.createdSetup).
 * No document ids, filenames, or user ids â€” scoped by carId (user-owned car).
 */
model SetupParameterAggregation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scopeType SetupAggregationScopeType @default(CAR_PARAMETER)
  scopeKey  String
  carId     String
  car       Car     @relation(fields: [carId], references: [id], onDelete: Cascade)

  parameterKey String
  valueType    SetupAggregationValueType

  sampleCount Int

  numericStatsJson     Json?
  categoricalStatsJson Json?

  @@unique([scopeType, scopeKey, carId, parameterKey])
  @@index([carId])
}

/**
 * App-wide parameter stats from every user's setup uploads flagged `eligibleForAggregationDataset`,
 * grouped by `Car.setupSheetTemplate` (same keys as CAR_PARAMETER, no per-user isolation).
 */
model CommunitySetupParameterAggregation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /** Matches `Car.setupSheetTemplate` (e.g. awesomatix_a800rr). */
  setupSheetTemplate String
  /** Parsed setup surface bucket (asphalt | carpet). */
  trackSurface String
  /**
   * Grip-level bucket derived from the doc's `traction` multi-select tag.
   * Values: `any` (always emitted â€” all eligible docs for the surface),
   * `low` / `medium` / `high` (one row per grip tag the doc claims; multi-tag docs land in multiple buckets).
   */
  gripLevel String @default("any")

  parameterKey String
  valueType    SetupAggregationValueType

  sampleCount Int

  numericStatsJson     Json?
  categoricalStatsJson Json?

  @@unique([setupSheetTemplate, trackSurface, gripLevel, parameterKey])
  @@index([setupSheetTemplate, trackSurface, gripLevel])
}

/**
 * Manufacturer baseline for a setup sheet (official PDF + optional summary).
 * One row per `setupSheetTemplate`; not counted in community aggregation sample stats.
 */
model SetupSheetManufacturerBaseline {
  setupSheetTemplate String @id
  /** Official manufacturer PDF URL (https recommended). */
  pdfUrl    String   @db.Text
  /** Optional short notes for the Engineer when the PDF is not parsed into rows. */
  summary   String?  @db.Text
  /** Last admin confirmation that pdfUrl/summary still match the current kit doc. */
  reviewedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/** User review for dataset / aggregation eligibility (bulk import workflow). */
enum SetupImportDatasetReviewStatus {
  UNSET
  NOT_CONFIRMED
  CONFIRMED_ACCURATE
}

/**
 * Bulk setup PDF import: label + files first; calibration and parse are per SetupDocument.
 */
model SetupImportBatch {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String?
  /** Optional batch default for future UX; not required for create/parse (per-document calibration is canonical). */
  calibrationProfileId String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  calibrationProfile SetupSheetCalibration? @relation(fields: [calibrationProfileId], references: [id], onDelete: SetNull)
  documents          SetupDocument[]

  @@index([userId, createdAt])
}

model SetupDocument {
  id               String                   @id @default(cuid())
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  originalFilename String
  storagePath      String
  mimeType         String
  sourceType       SetupDocumentSourceType
  parserType       String?
  parseStatus      SetupDocumentParseStatus @default(PENDING)
  importStatus     SetupDocumentImportStatus @default(PENDING)
  importOutcome    SetupDocumentImportOutcome?
  currentStage       String?
  lastCompletedStage String?
  stageStartedAt      DateTime?
  stageFinishedAt     DateTime?
  importDebugLogJson  Json?
  importDiagnosticJson Json?
  importErrorMessage String?
  parseStartedAt     DateTime?
  parseFinishedAt    DateTime?
  calibrationResolvedProfileId String?
  calibrationResolvedSource    String?
  calibrationResolvedDebug     String?
  calibrationUsedIsForcedDefault Boolean?
  extractedText    String?
  parsedDataJson   Json?
  /** Original source URL when imported from a remote site (e.g. PetitRC). */
  sourceUrl        String?
  /** Optional source tag (e.g. \"petitrc\"). */
  sourceSite       String?
  /** SHA-256 of the original PDF bytes (dedupe across URL variants and old imports). */
  sourceContentSha256 String?
  /** User corrected structured fields after parse (niche fixes; automated re-parse clears this). */
  parsedSetupManuallyEdited Boolean @default(false)
  /** Sticky calibration used for parse + render (forced default when missing). */
  calibrationProfileId String?
  calibrationProfile   SetupSheetCalibration? @relation("SetupDocumentCalibration", fields: [calibrationProfileId], references: [id], onDelete: SetNull)
  /** Calibration id actually used to produce current parsedDataJson (stale detection). */
  parsedCalibrationProfileId String?
  parsedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  car   Car?  @relation(fields: [carId], references: [id], onDelete: SetNull)
  carId String?
  /// Canonical `Car.setupSheetTemplate` (e.g. awesomatix_a800rr). Legacy; prefer setupSheetModelId.
  setupSheetTemplate String?
  setupSheetModelId  String?
  setupSheetModel    SetupSheetModel? @relation(fields: [setupSheetModelId], references: [id], onDelete: SetNull)

  setupImportBatchId String?
  setupImportBatch   SetupImportBatch? @relation(fields: [setupImportBatchId], references: [id], onDelete: Cascade)
  importDatasetReviewStatus    SetupImportDatasetReviewStatus @default(UNSET)
  /** True only when user confirmed accurate and parse succeeded (PARSED/PARTIAL). */
  eligibleForAggregationDataset Boolean @default(false)

  createdSetup   SetupSnapshot? @relation("CreatedSetup", fields: [createdSetupId], references: [id], onDelete: SetNull)
  createdSetupId String?
  exampleForCalibrations SetupSheetCalibration[] @relation("CalibrationExampleDocument")
  runsUsingAsPdfSource Run[] @relation("RunSetupPdfSource")

  @@index([userId, createdAt])
  @@index([userId, parseStatus])
  @@index([userId, setupSheetTemplate])
  @@index([userId, setupSheetModelId])
  @@index([setupSheetModelId])
  @@index([setupImportBatchId])
  @@index([carId])
  @@unique([userId, sourceUrl])
  @@unique([userId, sourceContentSha256])
}

model SetupSheetCalibration {
  id String @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name String
  sourceType String
  calibrationDataJson Json
  exampleDocumentId String?
  setupSheetModelId String?
  /**
   * Legacy flag from the community-shared top-3 promotion; calibrations are globally visible
   * regardless of this field while global mode is enabled.
   */
  communityShared Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  setupSheetModel SetupSheetModel? @relation(fields: [setupSheetModelId], references: [id], onDelete: SetNull)
  defaultForModel SetupSheetModel? @relation("ModelDefaultCalibration")
  exampleDocument SetupDocument? @relation("CalibrationExampleDocument", fields: [exampleDocumentId], references: [id], onDelete: SetNull)
  runsUsingCalibration Run[] @relation("RunSetupPdfCalibration")
  documentsUsingCalibration SetupDocument[] @relation("SetupDocumentCalibration")
  setupImportBatches        SetupImportBatch[]

  @@index([userId, createdAt])
  @@index([userId, setupSheetModelId])
  @@index([setupSheetModelId])
  @@index([communityShared, createdAt])
}

enum SessionType {
  TESTING
  PRACTICE
  RACE_MEETING
}

model Run {
  id                   String   @id @default(cuid())
  createdAt            DateTime @default(now())
  sessionLabel         String?  // Optional free-text; for Race Meeting used as override/additional only
  sessionType          SessionType  @default(TESTING)
  meetingSessionType   String?   // PRACTICE | SEEDING | QUALIFYING | RACE (only when sessionType = RACE_MEETING)
  meetingSessionCode   String?   // e.g. "1","2","3" for Practice/Race; "Q1","Q2","Q3" for Qualifying; enables timetableSessionId later
  carNameSnapshot      String?
  trackNameSnapshot    String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  car   Car?  @relation(fields: [carId], references: [id], onDelete: SetNull)
  carId String?

  track   Track?  @relation(fields: [trackId], references: [id], onDelete: SetNull)
  trackId String?

  event   Event?  @relation(fields: [eventId], references: [id])
  eventId String?

  /** Session race class when not from event, or override (e.g. \"17.5 Stock\"). */
  raceClass String?

  tireSet   TireSet? @relation(fields: [tireSetId], references: [id])
  tireSetId String?

  // Auto-increments per tire set based on last run with that set.
  tireRunNumber Int      @default(1)

  additiveType   AdditiveType? @relation(fields: [additiveTypeId], references: [id], onDelete: SetNull)
  additiveTypeId String?

  /** Optional warmer timing in minutes (independent of additive selection). */
  warmerTimingMinutes Int?

  battery   Battery? @relation(fields: [batteryId], references: [id])
  batteryId String?

  batteryRunNumber Int @default(1)

  setupSnapshot   SetupSnapshot @relation(fields: [setupSnapshotId], references: [id])
  setupSnapshotId String

  /** Base uploaded PDF used to render this runâ€™s setup sheet (derived PDF is separate). */
  sourceSetupDocumentId String?
  sourceSetupDocument   SetupDocument? @relation("RunSetupPdfSource", fields: [sourceSetupDocumentId], references: [id], onDelete: SetNull)
  /** Calibration / mapping profile used with the base PDF. */
  sourceSetupCalibrationId String?
  sourceSetupCalibration   SetupSheetCalibration? @relation("RunSetupPdfCalibration", fields: [sourceSetupCalibrationId], references: [id], onDelete: SetNull)
  /** Relative path under public/ for rendered run setup PDF (same bytes as in-app view). */
  renderedSetupPdfPath      String?
  renderedSetupPdfGeneratedAt DateTime?
  /** Increment when render pipeline changes; triggers re-render when mismatched. */
  setupPdfRenderVersion     Int      @default(1)

  // Store raw lap times as JSON array (SQLite-compatible; was Float[] for PostgreSQL).
  // Primary (self) laps â€” kept in sync with lapSession.entries[primary] when lapSession is set.
  lapTimes Json @default("[]")

  // Structured lap ingestion: source, metrics, multi-driver/field-ready entries (see src/lib/lapSession/types.ts).
  lapSession Json?

  /**
   * Materialized lap summary metrics computed from `lapTimes` / `lapSession` at
   * save time. List views (Sessions / dashboard) read these instead of
   * recomputing from the JSON lap arrays for every row. Nullable for legacy
   * runs written before the column existed â€” callers fall back to computing
   * from the lap arrays in that case.
   */
  bestLapSeconds   Float?
  avgTop5LapSeconds Float?

  notes            String?  // unified notes (new); legacy fields below for older runs
  driverNotes      String?
  handlingProblems String?
  /** Optional structured handling tags / balance / prompts (see runHandlingAssessment). */
  handlingAssessmentJson Json?
  /**
   * Required 1â€“10 overall car rating captured at "Run complete". Nullable in DB so legacy and
   * draft runs aren't broken, but the run-complete API path enforces it. Drives the
   * Engineer's `runQuality` signal + known-good / known-bad history mining.
   */
  carRating Int?
  suggestedChanges String?
  /** Preâ€“next-run reminders; same bullet format as `suggestedChanges` (ActionItem `THINGS_TO_DO`). */
  suggestedPreRun  String?
  appliedChanges   String?

  importedLapSets RunImportedLapSet[]
  actionItems     ActionItem[]

  /** Lap-time imports linked to this run (optional; see ImportedLapTimeSession). */
  linkedImportedLapSessions ImportedLapTimeSession[] @relation("ImportedLapSessionLinkedRun")

  /** Primary imported lap-time session when this run was created from detection / URL import. */
  importedLapTimeSessionId String?                 @unique
  detectedImportedLapSession ImportedLapTimeSession? @relation("RunDetectedImport", fields: [importedLapTimeSessionId], references: [id], onDelete: SetNull)

  /**
   * When the on-track session actually occurred (from timing import / LiveRC), if known.
   * Distinct from createdAt (when this row was saved in the app).
   */
  sessionCompletedAt DateTime?
  /** User finished the logging workflow (Run completed), or saved from event-detected import. */
  loggingComplete  Boolean  @default(false)
  /**
   * First server time when this run was saved with `loggingComplete` true (non-draft).
   * Immutable after set. Used for list timestamps so they stay on â€œwhen I finished loggingâ€
   * rather than re-imported session wall clock.
   *
   * Legacy completed rows may still be null; display falls back to `sessionCompletedAt` then
   * `createdAt`. Optional one-shot SQL: set to COALESCE(session_completed_at, created_at)
   * where logging_complete and logging_completed_at is null.
   */
  loggingCompletedAt DateTime?
  /** Dashboard / import chooser: hide "incomplete logging" reminder without deleting the run. */
  incompleteLoggingPromptDismissedAt DateTime?

  /**
   * Stable ordering axis for run lists. Stamped once at create time (= server `now()`)
   * and never auto-updated. Only changes when the user explicitly drags a run to a new
   * position (reorder endpoint) or opts in to "use session time". Display time-of-day
   * is independent (see `sessionCompletedAt` / `createdAt`); this column exists purely
   * so "if B was completed after A, B stays above A forever" holds regardless of edits,
   * re-imports, or lap-time changes. Backfilled from `COALESCE(sessionCompletedAt, createdAt)`.
   */
  sortAt DateTime @default(now())

  /**
   * When false, mutual team members do not see this run in team Sessions / team-only Engineer paths.
   * One-way TeammateLink visibility is unchanged (still sees the run).
   */
  shareWithTeam Boolean @default(true)

  /** Cached deterministic Engineer Summary JSON (invalidated on run update). */
  engineerSummaryJson         Json?
  engineerSummaryRefRunId     String?
  engineerSummaryComputedAt   DateTime?
  /** Optional structured Deep Dive answers (versioned object). */
  engineerDeepDiveJson        Json?

  /**
   * Optional URL to the practice day results page (e.g. LiveRC practice day)
   * that the Lap Times "url" ingest tab uses to list candidate sessions for this
   * driver. Captured per-run (vs the user-wide `currentPracticeDayUrl` setting)
   * so historical runs remember which day they came from even when the user
   * moves on to a new day.
   */
  practiceDayUrl String?

  betweenRunHint EngineerBetweenRunHint?
  dashboardSuggestion EngineerDashboardSuggestion?

  videoAnalysisJobs VideoAnalysisJob[]
  videoAssets         VideoAsset[]

  @@index([userId, sortAt])
  @@index([userId, carId, carRating])
}

/** Cached proactive â€œnext sessionâ€ hints for Dashboard / Engineer (LLM + fingerprint invalidation). */
model EngineerBetweenRunHint {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  primaryRunId String @unique
  primaryRun   Run    @relation(fields: [primaryRunId], references: [id], onDelete: Cascade)

  referenceRunId String?
  /** SHA-256 of summary + handling inputs; must match for cache hit. */
  inputFingerprint String
  /** Versioned BetweenRunHintPayload JSON. */
  payloadJson Json

  @@index([userId, updatedAt])
}

/** Cached handling/setup-oriented suggestions for Dashboard â€œEngineer suggestionsâ€ tab. */
model EngineerDashboardSuggestion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  primaryRunId String @unique
  primaryRun   Run    @relation(fields: [primaryRunId], references: [id], onDelete: Cascade)

  /** SHA-256 of notes, handling, setup ids, prior run id, and slim spread fingerprint. */
  inputFingerprint String
  /** Versioned dashboard suggestion payload JSON. */
  payloadJson Json

  @@index([userId, updatedAt])
}

/** Persisted Engineer chat thread for feedback / founder review. */
model EngineerChatThread {
  id        String   @id @default(cuid())
