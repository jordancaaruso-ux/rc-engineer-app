/** Single user or assistant turn in an Engineer chat thread. */
model EngineerChatMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  threadId String
  thread   EngineerChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  role    String
  content String @db.Text

