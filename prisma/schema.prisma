/** Auto-captured founder Engineer Q&A queued for gold-set review (T6 admin). */
model EngineerGoldSetCandidate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  threadId           String
  assistantMessageId String @unique

  /** pending | promoted | dismissed */
  status String @default("pending")

  question     String @db.Text
  questionHash String
  answer       String @db.Text

  runId        String?
  compareRunId String?
  kbSections   Json?
  source       String?

  reviewerJson      Json?
  reviewerReviewedAt DateTime?

  promotedAt     DateTime?
  promotedCaseId String?

