/** In-app 0–10 score (`stars` column) + optional note on an Engineer assistant message. */
model EngineerMessageRating {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messageId String
  message   EngineerChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

