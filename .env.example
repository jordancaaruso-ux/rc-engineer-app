# =============================================================================
# RC Engineer — environment variables
# Copy to `.env` / `.env.local` and fill values. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication (Auth.js / magic link)
# -----------------------------------------------------------------------------

## AUTH_SECRET — required in production. Generate: openssl rand -base64 32
AUTH_SECRET=""

## AUTH_URL — public site URL (e.g. https://your-app.vercel.app). Required for magic-link callbacks.
AUTH_URL="http://localhost:3000"

## AUTH_ALLOWED_EMAILS — comma-separated allowlist synced by `npx prisma db seed` into AuthAllowedEmail.
# Example: AUTH_ALLOWED_EMAILS="you@example.com,teammate@example.com"
AUTH_ALLOWED_EMAILS=""

## AUTH_ADMIN_EMAILS — comma-separated; these signed-in users see Settings → allowlist UI and may add/remove AuthAllowedEmail rows via API.
# AUTH_ADMIN_EMAILS="you@example.com"

## AUTH_DEV_ALLOW_ANY_EMAIL=1 — non-production only: skip allowlist (local dev convenience). Do not set in Vercel Production.
# AUTH_DEV_ALLOW_ANY_EMAIL=1

## EMAIL_SERVER / EMAIL_FROM — Nodemailer SMTP (required on Vercel for inbox magic links). Omit locally to log links to the dev terminal.
# Resend (no custom domain): API key as SMTP password, user "resend", host smtp.resend.com — confirm test From in Resend docs (e.g. onboarding@resend.dev).
# EMAIL_SERVER="smtps://resend:re_xxxxxxxx@smtp.resend.com:465"
# EMAIL_FROM="RC Engineer <onboarding@resend.dev>"
# Other providers:
# EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
# EMAIL_FROM="RC Engineer <no-reply@example.com>"

# -----------------------------------------------------------------------------
# REQUIRED for production (Vercel + Neon + Blob)
# -----------------------------------------------------------------------------

## DATABASE_URL (required)
# Postgres connection string. On Neon: Project → Connection string → URI (include `?sslmode=require` if shown).
# Vercel: add to Project → Settings → Environment Variables for Production (and Preview if needed).
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
DATABASE_URL=""

## BLOB_READ_WRITE_TOKEN (required on Vercel for durable PDF storage)
# Vercel Blob read/write token. On Vercel (VERCEL=1), uploads fail fast without this — local disk is not durable in serverless.
# Locally, without this token, PDFs go to `.local-uploads/` (or legacy `public/uploads/` for reads only).
# Dashboard: Storage → Blob → connect project → copy token into env.
# https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=""

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# DEBUG_ACCESS_GATE=1 — log middleware gate decisions in the dev terminal.
# DEBUG_SETUP_UPLOAD_TIMING=1 — log setup-sheet POST phases (formData, Blob put, DB) to find upload latency.
# DEBUG_SETUP_PROCESS_TIMING=1 — log POST /api/setup-documents/[id]/process stages (load, parse, extract, map, DB).
# DEBUG_ENGINEER_CHAT=1 — include error stack traces in /api/engineer/chat JSON (for UI) in production; dev always includes stack when NODE_ENV=development.

## CAPACITOR_SERVER_URL — origin the iOS shell loads (e.g. https://your-app.vercel.app). Used when running `npx cap sync ios`.
# CAPACITOR_SERVER_URL="https://your-app.vercel.app"

## OPENAI_API_KEY — lap times from timing screenshots (Vision). Server-only.
OPENAI_API_KEY=""

## Engineer chat (OpenAI Chat Completions)
# Default model is gpt-5. Set ENGINEER_MODEL to override (e.g. gpt-4o-mini when optimizing cost at scale).
# ENGINEER_MODEL="gpt-5"

## LAP_IMPORT_USER_AGENT — override default fetch user agent for lap URL import.
# LAP_IMPORT_USER_AGENT="MyApp/1.0"
