# =============================================================================
# RC Engineer — environment variables
# Copy to `.env` / `.env.local` and fill values. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED for production (Vercel + Neon + Blob)
# -----------------------------------------------------------------------------

## DATABASE_URL (required)
# Postgres connection string. On Neon: Project → Connection string → URI (include `?sslmode=require` if shown).
# Vercel: add to Project → Settings → Environment Variables for Production (and Preview if needed).
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
DATABASE_URL=""

## ACCESS_PASSWORD (required if you use the app password gate)
# When set, middleware enforces login via /login and cookie `rc-auth`.
# When unset, the gate is off (fine for trusted local dev only — not for public URLs).
# Production: set a strong secret; rotate by changing the value and clearing cookies.
ACCESS_PASSWORD=""

## BLOB_READ_WRITE_TOKEN (required on Vercel for durable PDF storage)
# Vercel Blob read/write token. On Vercel (VERCEL=1), uploads fail fast without this — local disk is not durable in serverless.
# Locally, without this token, PDFs go to `.local-uploads/` (or legacy `public/uploads/` for reads only).
# Dashboard: Storage → Blob → connect project → copy token into env.
# https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=""

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# DEBUG_ACCESS_GATE=1 — log middleware gate decisions in the dev terminal.
# DEBUG_SETUP_UPLOAD_TIMING=1 — log setup-sheet POST phases (formData, Blob put, DB) to find upload latency.
# DEBUG_SETUP_PROCESS_TIMING=1 — log POST /api/setup-documents/[id]/process stages (load, parse, extract, map, DB).

## OPENAI_API_KEY — lap times from timing screenshots (Vision). Server-only.
OPENAI_API_KEY=""

## LAP_IMPORT_USER_AGENT — override default fetch user agent for lap URL import.
# LAP_IMPORT_USER_AGENT="MyApp/1.0"
