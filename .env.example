## Prisma – local development (SQLite)
# File-based database; no external server. Created by: npx prisma migrate dev
DATABASE_URL="file:./dev.db"

## Production (optional – PostgreSQL)
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/rc_engineer?schema=public"

## Lap import – photo / screenshot (OpenAI Vision)
# Required for automatic lap read from uploaded timing screenshots.
# Put secrets in `.env.local` (gitignored) or `.env`; restart `next dev` after changes.
# The key is server-only — `process.env.OPENAI_API_KEY` in the browser console is always empty.
OPENAI_API_KEY=""

## Lap import – URL fetch (optional)
# Defaults to a neutral UA; override if a timing site blocks the default.
# LAP_IMPORT_USER_AGENT="MyApp/1.0"

