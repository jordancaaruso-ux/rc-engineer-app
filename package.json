{
  "name": "rc-engineer",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "npx dotenv-cli -e .env.local -- npx tsx prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "node scripts/vercel-build.cjs",
    "start": "next start",
    "lint": "eslint .",
    "prisma": "prisma",
    "db:push": "npx dotenv-cli -e .env.local -- prisma db push",
    "db:seed": "npx dotenv-cli -e .env.local -- prisma db seed",
    "db:migrate:deploy": "npx dotenv-cli -e .env.local -- prisma migrate deploy",
    "db:migrate:resolve:rolled-back": "npx dotenv-cli -e .env.local -- prisma migrate resolve --rolled-back",
    "db:migrate:resolve:applied": "npx dotenv-cli -e .env.local -- prisma migrate resolve --applied",
    "db:migrate:reconcile": "npx dotenv-cli -e .env.local -- node scripts/reconcile-prisma-migrations.cjs",
    "db:migrate:resolve:action-item-prerun": "npx dotenv-cli -e .env.local -- prisma migrate resolve --applied 20260427120000_action_item_list_kind_and_suggested_prerun",
    "db:migrate:resolve:teams-pilot": "npx dotenv-cli -e .env.local -- prisma migrate resolve --applied 20260427183000_teams_pilot",
    "db:migrate:resolve:run-share-with-team": "npx dotenv-cli -e .env.local -- prisma migrate resolve --applied 20260428120000_run_share_with_team",
    "test:grip-spread": "npx tsx src/lib/engineerPhase5/gripSpreadContrast.test.ts",
    "test:between-hints": "npx tsx src/lib/engineerPhase5/betweenRunHints/betweenRunHints.test.ts",
    "test:engineering-read": "npx tsx src/lib/engineerPhase5/engineeringRead.test.ts",
    "test:quick-fix": "npx tsx src/lib/engineerPhase5/quickFix/quickFix.test.ts",
    "test:intent": "node --conditions=react-server --import tsx src/lib/engineerPhase5/parameterEffects/intentFromMessage.test.ts",
    "test:mechanism-outcomes": "node --conditions=react-server --import tsx src/lib/engineerPhase5/parameterEffects/mechanismOutcomes.test.ts",
    "test:reasoning-spine": "node --conditions=react-server --import tsx src/lib/engineerPhase5/reasoningSpine/reasoningSpine.test.ts",
    "test:spine-routes": "npx tsx src/lib/engineerPhase5/reasoningSpine/parseRoutes.test.ts",
    "test:video-analysis": "npx tsx src/lib/videoAnalysis/sectorStats.test.ts",
    "test:manual-video-analysis": "npx tsx src/lib/manualVideoAnalysis/sync.test.ts",
    "test:setup-model-dedupe": "npx tsx src/lib/setupSheetModels/dedupeElection.test.ts",
    "test:picker-models": "npx tsx src/lib/setupSheetModels/pickerModels.test.ts",
    "test:fingerprint-scope": "npx tsx src/lib/setupCalibrations/scopeCandidates.test.ts",
    "test:engineer-ratings": "npx tsx src/lib/engineerFeedback/ratingValidation.test.ts && npx tsx src/lib/engineerFeedback/adminFeedbackAccess.test.ts",
    "test:engineer-export-feedback": "npx tsx src/lib/engineerFeedback/exportFeedbackInbox.test.ts && npx tsx src/lib/engineerFeedback/zipStore.test.ts",
    "test:engineer-reviewer": "npx tsx src/lib/engineerFeedback/reviewerParse.test.ts",
    "test:engineer-gold-set": "npx tsx src/lib/engineerFeedback/goldSetCandidate.test.ts",
    "engineer:eval": "npx dotenv-cli -e .env.local -- node --conditions=react-server --import tsx scripts/engineer-eval/run-eval.ts",
    "engineer:sync-gold-set": "npx dotenv-cli -e .env.local -- npx tsx scripts/engineer-eval/sync-gold-set.ts",
    "engineer:export-feedback": "npx dotenv-cli -e .env.local -- npx tsx scripts/engineer-eval/export-feedback.ts",
    "kb:coverage": "node scripts/kb-coverage-report.cjs",
    "kb:index": "node scripts/build-kb-chunk-index.cjs",
    "check:legacy-local-user": "npx tsx scripts/check-legacy-local-user.ts",
    "backfill:setup-car": "npx tsx scripts/backfill-setup-documents-car-id.ts",
    "db:prune-calibrations": "npx tsx scripts/prune-calibrations-keep-community-shared.ts",
    "db:dedupe:setup-models": "npx dotenv-cli -e .env.local -- npx tsx scripts/dedupe-setup-sheet-models.ts",
    "db:dedupe:events": "npx dotenv-cli -e .env.local -- npx tsx scripts/dedupe-events.ts",
    "db:seed:additives": "npx dotenv-cli -e .env.local -- npx tsx scripts/sync-additive-types.ts",
    "cap:sync": "cap sync ios",
    "cap:open": "cap open ios"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@prisma/client": "^6.19.2",
    "@vercel/blob": "^2.3.2",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "next": "latest",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdf2json": "^4.0.2",
    "pdfjs-dist": "^5.5.207",
    "react": "latest",
    "react-dom": "latest",
    "react-pdf": "^10.4.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "latest",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "dotenv-cli": "^11.0.0",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "^8.5.8",
    "prisma": "^6.0.0",
    "tailwindcss": "latest",
    "tsx": "^4.19.4",
    "typescript": "latest"
  }
}
